{
  "name": "billing-system",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k \"node server.js\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build --webpack && electron-builder --win",
    "electron:build:mac": "next build --webpack && electron-builder --mac",
    "electron:build:linux": "next build --webpack && electron-builder --linux",
    "electron:build:all": "next build --webpack && electron-builder -mwl"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@reduxjs/toolkit": "^2.3.0",
    "@studio-freight/lenis": "^1.0.42",
    "@types/bcryptjs": "^2.4.6",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "lenis": "^1.3.23",
    "lucide-react": "^0.460.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.1.2",
    "recharts": "^2.13.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.billingsystem.app",
    "productName": "Enterprise Billing System",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "**/*",
      "!**/.next/dev/**",
      "!**/.next/cache/**",
      "!**/node_modules/.cache/**",
      "!dist-electron/**",
      "!src/**"
    ],
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true
    }
  }
}
